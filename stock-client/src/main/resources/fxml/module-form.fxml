<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.handk.client.controller.ModuleFormController" spacing="10" prefWidth="520">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <Label fx:id="titleLabel" text="表单" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <GridPane hgap="8" vgap="8">
        <Label text="ID" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="idField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="用户名" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="usernameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="部门ID" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="deptIdField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="密码" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="passwordField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="邮箱" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="手机号" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="名称" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="编码" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="codeField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="地址" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextField fx:id="addressField" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        <Label text="负责人ID" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <TextField fx:id="managerIdField" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

        <Label text="商品ID" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <TextField fx:id="goodsIdField" GridPane.rowIndex="10" GridPane.columnIndex="1"/>

        <Label text="商品名" GridPane.rowIndex="11" GridPane.columnIndex="0"/>
        <TextField fx:id="goodsNameField" GridPane.rowIndex="11" GridPane.columnIndex="1"/>

        <Label text="SKU ID" GridPane.rowIndex="12" GridPane.columnIndex="0"/>
        <TextField fx:id="skuIdField" GridPane.rowIndex="12" GridPane.columnIndex="1"/>

        <Label text="SKU 编码" GridPane.rowIndex="13" GridPane.columnIndex="0"/>
        <TextField fx:id="skuCodeField" GridPane.rowIndex="13" GridPane.columnIndex="1"/>

        <Label text="仓库ID" GridPane.rowIndex="14" GridPane.columnIndex="0"/>
        <TextField fx:id="warehouseIdField" GridPane.rowIndex="14" GridPane.columnIndex="1"/>

        <Label text="现有库存" GridPane.rowIndex="15" GridPane.columnIndex="0"/>
        <TextField fx:id="currentQtyField" GridPane.rowIndex="15" GridPane.columnIndex="1"/>

        <Label text="锁定库存" GridPane.rowIndex="16" GridPane.columnIndex="0"/>
        <TextField fx:id="lockQtyField" GridPane.rowIndex="16" GridPane.columnIndex="1"/>

        <Label text="价格" GridPane.rowIndex="17" GridPane.columnIndex="0"/>
        <TextField fx:id="priceField" GridPane.rowIndex="17" GridPane.columnIndex="1"/>

        <Label text="币种" GridPane.rowIndex="18" GridPane.columnIndex="0"/>
        <TextField fx:id="currencyField" GridPane.rowIndex="18" GridPane.columnIndex="1"/>

        <Label text="库存类型ID" GridPane.rowIndex="19" GridPane.columnIndex="0"/>
        <TextField fx:id="stockTypeIdField" GridPane.rowIndex="19" GridPane.columnIndex="1"/>

        <Label text="状态" GridPane.rowIndex="20" GridPane.columnIndex="0"/>
        <ComboBox fx:id="statusCombo" GridPane.rowIndex="20" GridPane.columnIndex="1" prefWidth="220"/>
    </GridPane>
    <Label fx:id="errorLabel" style="-fx-text-fill: #c62828;"/>
    <HBox spacing="8">
        <Button fx:id="saveButton" text="保存" onAction="#onSave"/>
        <Button text="取消" onAction="#onCancel"/>
    </HBox>
</VBox>
