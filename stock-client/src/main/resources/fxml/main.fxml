<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.handk.client.controller.MainController" prefWidth="1360" prefHeight="820" styleClass="app-root">
    <left>
        <VBox prefWidth="270" styleClass="side-wrap">
            <padding>
                <Insets top="14" right="12" bottom="14" left="12"/>
            </padding>
            <Label text="库存管理" styleClass="brand"/>
            <Accordion VBox.vgrow="ALWAYS" styleClass="side-accordion">
                <panes>
                    <TitledPane text="基础主数据" expanded="true">
                        <content>
                            <VBox spacing="6" styleClass="menu-group">
                                <Button text="用户管理" userData="user" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="部门管理" userData="dept" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="仓库管理" userData="warehouse" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="角色管理" userData="role" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="权限管理" userData="permission" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </content>
                    </TitledPane>
                    <TitledPane text="商品管理">
                        <content>
                            <VBox spacing="6" styleClass="menu-group">
                                <Button text="商品管理" userData="goods" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="会员价格" userData="goodsLevelPrice" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="制造商管理" userData="maker" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="品牌管理" userData="brand" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="分类管理" userData="category" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="系列管理" userData="series" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </content>
                    </TitledPane>
                    <TitledPane text="库存管理">
                        <content>
                            <VBox spacing="6" styleClass="menu-group">
                                <Button text="库存列表" userData="stock" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="库存区分" userData="stockType" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="库存履历" userData="stockRecord" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="入出库单据" userData="stockOrder" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="入出库明细" userData="stockOrderItem" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="申请管理" userData="requestForm" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="申请明细" userData="requestItem" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="价格履历" userData="priceRecord" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </content>
                    </TitledPane>
                    <TitledPane text="客户管理">
                        <content>
                            <VBox spacing="6" styleClass="menu-group">
                                <Button text="客户管理" userData="customer" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="客户等级" userData="customerLevel" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </content>
                    </TitledPane>
                    <TitledPane text="系统管理">
                        <content>
                            <VBox spacing="6" styleClass="menu-group">
                                <Button text="系统设置" userData="config" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="消息管理" userData="message" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                                <Button text="操作日志" userData="operateLog" onAction="#onNavSelect" maxWidth="1.7976931348623157E308"/>
                            </VBox>
                        </content>
                    </TitledPane>
                </panes>
            </Accordion>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <padding>
                <Insets top="10" right="16" bottom="10" left="16"/>
            </padding>
            <Label fx:id="pageTitleLabel" text="用户管理" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="languageCombo" prefWidth="120" onAction="#onLanguageChange"/>
            <Label fx:id="currentUserLabel" text="当前用户" styleClass="user-chip"/>
            <Button text="退出登录" onAction="#onLogout" styleClass="link-btn"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="content-wrap">
            <VBox spacing="10" styleClass="search-panel">
                <FlowPane fx:id="queryFieldsPane" hgap="8" vgap="8" prefWrapLength="900"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Button text="查询" onAction="#onSearch" styleClass="primary-btn"/>
                    <Button text="重置" onAction="#onRefresh"/>
                    <Button text="上一页" onAction="#onPrevPage"/>
                    <Button text="下一页" onAction="#onNextPage"/>
                    <Label fx:id="pageInfoLabel" styleClass="muted-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="新增" onAction="#onAdd" styleClass="success-btn"/>
                    <Button text="行内编辑" onAction="#onInlineEdit"/>
                    <Button text="保存行编辑" onAction="#onInlineSave" styleClass="success-btn"/>
                    <Button text="取消行编辑" onAction="#onInlineCancel"/>
                    <Button text="编辑" onAction="#onEdit"/>
                    <Button text="批量删除" onAction="#onBatchDelete" styleClass="danger-btn"/>
                    <TextField fx:id="deleteIdField" promptText="ID" prefWidth="90"/>
                    <Button text="删除" onAction="#onDelete" styleClass="danger-btn"/>
                </HBox>
            </VBox>

            <VBox spacing="8" styleClass="table-panel" VBox.vgrow="ALWAYS">
                <TableView fx:id="dataTable" editable="true" VBox.vgrow="ALWAYS"/>
                <Label fx:id="messageLabel" styleClass="hint-label" wrapText="true"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>