<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="co.handk.client.controller.LoginController" styleClass="login-root">
    <VBox maxWidth="460" spacing="14" styleClass="login-card">
        <padding>
            <Insets top="26" right="26" bottom="26" left="26"/>
        </padding>

        <Label text="%login.title" styleClass="login-title"/>
        <Label text="%login.subtitle" styleClass="login-subtitle"/>

        <TextField fx:id="usernameField" promptText="%login.username" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="%login.password" styleClass="input-field"/>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <CheckBox fx:id="rememberCheckBox" text="%login.remember"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <Button text="%login.submit" onAction="#onLogin" styleClass="primary-btn" maxWidth="1.7976931348623157E308"/>
        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
    </VBox>
</StackPane>
