<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.handk.client.controller.LoginController" spacing="10">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <TextField fx:id="usernameField" promptText="用户名"/>
    <PasswordField fx:id="passwordField" promptText="密码"/>
    <Button text="登录" onAction="#onLogin"/>
    <Label fx:id="messageLabel"/>
</VBox>
