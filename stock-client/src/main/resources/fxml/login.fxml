<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.handk.client.controller.LoginController" styleClass="login-root">
    <VBox maxWidth="420" spacing="14" styleClass="login-card">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <Label text="Stock Admin" styleClass="login-title"/>
        <Label text="库存管理客户端" styleClass="login-subtitle"/>

        <TextField fx:id="usernameField" promptText="用户名" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="密码" styleClass="input-field"/>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <CheckBox fx:id="rememberCheckBox" text="记住用户名和密码"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <Button text="登录" onAction="#onLogin" styleClass="primary-btn" maxWidth="1.7976931348623157E308"/>
        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
    </VBox>
</StackPane>